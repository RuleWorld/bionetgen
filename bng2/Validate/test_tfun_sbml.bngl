# Test tfun SBML export
begin model

begin parameters
end parameters

begin molecule types
    X()
end molecule types

begin seed species
    X() 0
end seed species

begin observables
    Molecules Xtot X()
end observables

begin functions
    # Test file-based tfun
    f_file() = tfun('test_data.tfun', time)

    # Test inline tfun
    f_inline() = tfun([0, 1, 2], [0, 10, 20], time)
end functions

begin reaction rules
    0 -> X() f_file()
end reaction rules

end model

generate_network({overwrite=>1})
writeSBML({})
