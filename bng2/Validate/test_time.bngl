# Test case for issue #222: time() function gives inaccurate results in ODE simulations
# The builtin time() function should give accurate results when used in rate expressions
# during ODE integration, not just at output steps.

begin model

begin parameters
end parameters

begin molecule types
    T()  # For tracking time via integration
    A()  # For tracking with f_correct()
    B()  # For tracking with f_builtin()
end molecule types

begin seed species
    T() 0
    A() 0
    B() 0
end seed species

begin observables
    Molecules t T()
    Molecules x_exact A()
    Molecules x_builtin B()
end observables

begin functions
    # This uses the integrated time observable as a workaround (should be accurate)
    f_correct() = t

    # This uses the builtin time() function
    f_builtin() = time()

    # Function to test difference between methods
    f_diff() = f_correct() - f_builtin()
end functions

begin reaction rules
    # Integrate time by producing T molecules at rate 1
    0 -> T() 1

    # Produce A at rate f_correct() - should equal time
    0 -> A() f_correct()

    # Produce B at rate f_builtin() - should also equal time
    0 -> B() f_builtin()
end reaction rules

end model

# Use strict tolerances to ensure integration accuracy
generate_network({overwrite=>1})
simulate({method=>"ode",t_end=>10,n_steps=>100,print_functions=>1,atol=>1e-12,rtol=>1e-12})